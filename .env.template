# dill.pkl environment configuration

# Application
APP_NAME="dill.pkl AutoML"
APP_ENV="development"
LOG_LEVEL="INFO"

# LLM / OpenRouter
# Required only if you want to use LLM-powered features.
OPENROUTER_API_KEY=""
MODEL_NAME="arcee-ai/trinity-large-preview:free"
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=2000

# Runtime
REQUEST_TIMEOUT=60
MAX_RETRIES=3

# Pipeline defaults
DEFAULT_TEST_SIZE=0.2
DEFAULT_RANDOM_STATE=42
DEFAULT_CV_FOLDS=5
