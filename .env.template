# dill.pkl environment configuration

# Application
APP_NAME="dill.pkl AutoML"
APP_ENV="development"
LOG_LEVEL="INFO"

# LLM / OpenRouter
# Required only if you want to use LLM-powered features.
OPENROUTER_API_KEY=""
MODEL_NAME="arcee-ai/trinity-large-preview:free"
CHAT_MODEL_NAME=""
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=2000

# Runtime
REQUEST_TIMEOUT=60
MAX_RETRIES=3

# Pipeline defaults
DEFAULT_TEST_SIZE=0.2
DEFAULT_RANDOM_STATE=42
DEFAULT_CV_FOLDS=5

# Advanced AutoML settings
ENABLE_MULTI_MODEL=true        # Compare multiple candidate models and pick the best
ENABLE_HPO=true                # Run Optuna hyperparameter optimisation
N_HPO_TRIALS=20                # Number of Optuna trials per model
ENABLE_ENSEMBLE=false          # Build a stacking/voting ensemble from top models
ENSEMBLE_TYPE=stacking         # Ensemble strategy: stacking or voting
ENSEMBLE_TOP_K=3               # How many top models to include in the ensemble
PARALLEL_TRAINING=true         # Train candidate models in parallel
